generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inquiry {
  id        String   @id @default(cuid())
  brand     String
  name      String
  subject   String
  assignee  String
  updatedAt DateTime @updatedAt
  status    String
}

model Invoice {
  id            String    @id @default(cuid())
  brand         String
  studentId     String?
  studentName   String
  assignee      String    @default("未設定")
  status        String
  sentDate      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
